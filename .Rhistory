)
p_duration_curve <- ggplot(duration_counts, aes(x = duration, y = prop_remaining, color = direction_label)) +
geom_line(size = 1.2) +
geom_point(size = 3) +
scale_x_continuous(breaks = 1:10) +
scale_y_continuous(labels = scales::percent) +
scale_color_manual(values = c("User -> AI (Same Turn)" = "#377EB8",
"AI -> User (Next Turn)" = "#FF7F00")) +
labs(
title = "Persistence of Emotional Alignment",
subtitle = "Percentage of alignment streaks lasting at least X turns",
x = "Duration (Consecutive Turns)",
y = "Proportion of Streaks Remaining",
color = "Direction"
) +
theme(legend.position = "top")
print(p_duration_curve)
ggsave(file.path(GRAPHS_DIR, "alignment_duration_survival.png"), p_duration_curve, width = 10, height = 6)
# Statistical Test: Wilcoxon Rank Sum Test for Durations
# (Are streaks in one direction statistically longer?)
wilcox_test <- wilcox.test(duration ~ direction_label, data = alignment_durations)
cat("\n=== Wilcoxon Rank Sum Test: Alignment Duration ===\n")
print(wilcox_test)
# Create summary table
summary_results <- tribble(
~Metric, ~Field_Data, ~Simulated_Data,
"N Stories", n_distinct(df_field$conversation_id), n_distinct(df_simulated$conversation_id),
"Mean User Valence", mean(df_field$user_valence, na.rm = TRUE), mean(df_simulated$user_valence, na.rm = TRUE),
"Mean AI Valence", mean(df_field$ai_valence, na.rm = TRUE), mean(df_simulated$ai_valence, na.rm = TRUE),
"Same-Turn Alignment (ρ)", mean(cor_field_same$rho, na.rm = TRUE), mean(cor_sim_same$rho, na.rm = TRUE),
"Previous-Turn Alignment (ρ)", mean(cor_field_prev$rho, na.rm = TRUE), mean(cor_sim_prev$rho, na.rm = TRUE)
) %>%
mutate(
Field_Data = round(Field_Data, 3),
Simulated_Data = round(Simulated_Data, 3)
)
print(summary_results)
write_csv(summary_results, file.path(TABLES_DIR, "analysis_summary.csv"))
