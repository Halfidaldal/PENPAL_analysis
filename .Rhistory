filter(turn >= 1, turn <= 5, !is.na(cosine_sim_same), !is.na(llm_type))
lm_alignment_llm <- lm(cosine_sim_same ~ turn * factor(llm_type) + (1 | conversation_id), data = df_alignment_llm)
lm_alignment_llm <- lm(cosine_sim_same ~ turn * factor(llm_type) + (1 | conversation_id), data = df_alignment_llm)
