legend.position = "top",
axis.title = element_text(size = 14, face = "bold"),
axis.text = element_text(size = 12)
)
print(p_cosine_comparison)
ggsave(file.path(GRAPHS_DIR, "cosine_similarity_comparison_same_vs_prev.png"),
p_cosine_comparison, width = 12, height = 6, dpi = 300)
p_valence_gap_comparison_lm <- lmer(valence_gap ~ turn * lag_type + (1 | conversation_id), data = df_valence_long)
summary(p_valence_gap_comparison_lm)
