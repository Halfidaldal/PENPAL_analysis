print(p_cosine_user_self_vs_interlocutor)
ggsave(file.path(GRAPHS_DIR, "cosine_similarity_user_self_vs_interlocutor.png"),
p_cosine_user_self_vs_interlocutor, width = 10, height = 6, dpi = 300)
# Calculate valence distances
df_field_val <- df_field %>%
mutate(
val_dist_same = abs(user_valence - ai_valence),
val_dist_prev = abs(user_valence - ai_valence_lag1),
val_dist_user_self = abs(user_valence - user_valence_lag1),
val_dist_ai_self = abs(ai_valence - ai_valence_lag1)
)
# User: Self vs Partner (Prev)
df_field_val_long_user <- df_field_val %>%
pivot_longer(cols = c(val_dist_user_self, val_dist_prev),
names_to = "direction", values_to = "val_dist") %>%
mutate(direction = recode(direction,
val_dist_user_self = "Self",
val_dist_prev = "Interlocutor"),
direction = factor(direction, levels = c("Self", "Interlocutor")))
# AI: Self vs Partner (Same)
df_field_val_long_ai <- df_field_val %>%
pivot_longer(cols = c(val_dist_ai_self, val_dist_same),
names_to = "direction", values_to = "val_dist") %>%
mutate(direction = recode(direction,
val_dist_ai_self = "Self",
val_dist_same = "Interlocutor"),
direction = factor(direction, levels = c("Self", "Interlocutor")))
cat("\n=== Valence Distance Model: User (Self vs Interlocutor) ===\n")
val_model_user <- lmer(val_dist ~ direction + (direction | conversation_id),
data = df_field_val_long_user)
print(round(summary(val_model_user)$coefficients, 4))
cat("\n=== Valence Distance Model: AI (Self vs Interlocutor) ===\n")
val_model_ai <- lmer(val_dist ~ direction + (direction | conversation_id),
data = df_field_val_long_ai)
print(round(summary(val_model_ai)$coefficients, 4))
# Combine for plotting
df_val_plot <- bind_rows(
df_field_val_long_user %>% mutate(agent = "User"),
df_field_val_long_ai %>% mutate(agent = "LLM")
)
p_val_dist <- df_val_plot %>%
ggplot(aes(x = direction, y = val_dist, fill = direction)) +
geom_violin(width = 0.6, alpha = 0.7) +
geom_boxplot(width = 0.2, outlier.shape = NA, alpha = 0.5,
position = position_dodge(width = 0.75)) +
facet_wrap(~ agent) +
scale_fill_manual(values = c("Self" = "#377EB8", "Interlocutor" = "#FF7F00")) +
labs(
title = "Valence Distance: Self vs Interlocutor Alignment",
subtitle = "Lower distance = Higher alignment",
x = "Alignment Target",
y = "Absolute Valence Distance"
) +
theme(
legend.position = "none",
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
strip.text = element_text(size = 14, face = "bold")
)
print(p_val_dist)
ggsave(file.path(GRAPHS_DIR, "valence_distance_comparison.png"),
p_val_dist, width = 12, height = 6, dpi = 300)
# 1. Calculate Velocity and Alignment Flags
df_dynamics <- df_field %>%
group_by(conversation_id) %>%
arrange(turn) %>%
mutate(
# Calculate change from previous turn (Velocity)
delta_user = user_valence - lag(user_valence),
delta_ai   = ai_valence - lag(ai_valence),
# Define Alignment: Signs of change match
# Exclude cases where change is exactly 0 (no movement)
# DIRECTION 1: User -> AI (Same Turn Response)
# Does AI move in same direction User just moved?
is_aligned_same = sign(delta_user) == sign(delta_ai) & delta_user != 0 & delta_ai != 0,
# DIRECTION 2: AI -> User (Next Turn Response)
# Does User move in same direction AI moved in previous turn?
# Compare User(t) delta with AI(t-1) delta
# lag(delta_ai) is delta at t-1 (Change from t-2 to t-1)
is_aligned_prev = sign(delta_user) == sign(lag(delta_ai)) & delta_user != 0 & lag(delta_ai) != 0
) %>%
ungroup()
# 2. Extract Run Lengths (Streak Durations)
get_run_lengths <- function(x) {
# Ensure input is a standard atomic vector (removes attributes)
x <- as.vector(x)
# Return empty if null or all NA
if(length(x) == 0 || all(is.na(x))) return(numeric(0))
# Filter NAs explicitly (cleaner than na.omit for rle)
x <- x[!is.na(x)]
# Double check length after filtering
if(length(x) == 0) return(numeric(0))
r <- rle(x)
# Return lengths where value is TRUE
return(r$lengths[r$values == TRUE])
}
alignment_durations <- df_dynamics %>%
group_by(conversation_id) %>%
summarise(
duration_same = list(get_run_lengths(is_aligned_same)),
duration_prev = list(get_run_lengths(is_aligned_prev))
) %>%
pivot_longer(cols = c(duration_same, duration_prev),
names_to = "direction",
values_to = "duration") %>%
unnest(duration) %>%
mutate(
direction_label = recode(direction,
duration_same = "User -> AI (Same Turn)",
duration_prev = "AI -> User (Next Turn)")
)
# 3. Calculate General Alignment Frequency (Hypothesis: User->AI is more frequent)
alignment_frequency <- df_dynamics %>%
pivot_longer(cols = c(is_aligned_same, is_aligned_prev),
names_to = "direction",
values_to = "is_aligned") %>%
filter(!is.na(is_aligned)) %>%
group_by(direction) %>%
summarise(
total_turns = n(),
aligned_turns = sum(is_aligned),
prop_aligned = aligned_turns / total_turns
) %>%
mutate(
direction_label = recode(direction,
is_aligned_same = "User -> AI (Same Turn)",
is_aligned_prev = "AI -> User (Next Turn)")
)
# Plot Overall Frequency
p_freq <- ggplot(alignment_frequency, aes(x = direction_label, y = prop_aligned, fill = direction_label)) +
geom_col(width = 0.6, alpha = 0.8) +
geom_text(aes(label = scales::percent(prop_aligned, accuracy = 0.1)),
vjust = -0.5, size = 5, fontface = "bold") +
scale_y_continuous(labels = scales::percent_format(), limits = c(0, 0.8)) + # Scale approx
scale_fill_manual(values = c("User -> AI (Same Turn)" = "#377EB8",
"AI -> User (Next Turn)" = "#FF7F00")) +
labs(
title = "Frequency of Directional Alignment",
subtitle = "Proportion of turns where responder moves in same direction as initiator",
x = NULL,
y = "Alignment Probability"
) +
theme(legend.position = "none")
print(p_freq)
ggsave(file.path(GRAPHS_DIR, "alignment_frequency_bar.png"), p_freq, width = 8, height = 5)
# Statistical Test (Proportions Test)
prop_test <- prop.test(
x = alignment_frequency$aligned_turns,
n = alignment_frequency$total_turns
)
cat("\n=== Proportions Test: Alignment Frequency ===\n")
print(prop_test)
# Calculate summary stats for durations
duration_stats <- alignment_durations %>%
group_by(direction_label) %>%
summarise(
mean_duration = mean(duration),
median_duration = median(duration),
max_duration = max(duration),
n_streaks = n()
)
print(duration_stats)
# Plot: Survival Curve style (Retention of Alignment)
# showing % of streaks that last at least X turns
duration_counts <- alignment_durations %>%
group_by(direction_label, duration) %>%
summarise(count = n(), .groups = "drop") %>%
group_by(direction_label) %>%
arrange(desc(duration)) %>%
mutate(
cum_count = cumsum(count),
total_streaks = max(cum_count), # max cumsum is total streaks
prop_remaining = cum_count / total_streaks
)
p_duration_curve <- ggplot(duration_counts, aes(x = duration, y = prop_remaining, color = direction_label)) +
geom_line(size = 1.2) +
geom_point(size = 3) +
scale_x_continuous(breaks = 1:10) +
scale_y_continuous(labels = scales::percent) +
scale_color_manual(values = c("User -> AI (Same Turn)" = "#377EB8",
"AI -> User (Next Turn)" = "#FF7F00")) +
labs(
title = "Persistence of Emotional Alignment",
subtitle = "Percentage of alignment streaks lasting at least X turns",
x = "Duration (Consecutive Turns)",
y = "Proportion of Streaks Remaining",
color = "Direction"
) +
theme(legend.position = "top")
print(p_duration_curve)
ggsave(file.path(GRAPHS_DIR, "alignment_duration_survival.png"), p_duration_curve, width = 10, height = 6)
# Statistical Test: Wilcoxon Rank Sum Test for Durations
# (Are streaks in one direction statistically longer?)
wilcox_test <- wilcox.test(duration ~ direction_label, data = alignment_durations)
cat("\n=== Wilcoxon Rank Sum Test: Alignment Duration ===\n")
print(wilcox_test)
# Create summary table
slopes_summary <- as.data.frame(slopes)
beta_user_to_ai <- slopes_summary[slopes_summary$alignment_direction == "User_to_AI", "predictor_z.trend"]
beta_ai_to_user <- slopes_summary[slopes_summary$alignment_direction == "AI_to_User", "predictor_z.trend"]
summary_results <- tribble(
~Metric, ~User, ~LLM,
"Mean Valence", mean(df_field$user_valence, na.rm = TRUE), mean(df_field$ai_valence, na.rm = TRUE),
"Sentiment Alignment (β)", beta_user_to_ai, beta_ai_to_user,
"Alignment Frequency (%)", alignment_frequency$prop_aligned[alignment_frequency$direction == "is_aligned_prev"] * 100, alignment_frequency$prop_aligned[alignment_frequency$direction == "is_aligned_same"] * 100,
"Mean Alignment Duration (turns)", duration_stats$mean_duration[duration_stats$direction_label == "AI -> User (Next Turn)"], duration_stats$mean_duration[duration_stats$direction_label == "User -> AI (Same Turn)"],
"Semantic Alignment (Cosine)", mean(df_field_cosine_long_prev_self$cosine_sim[df_field_cosine_long_prev_self$direction == "Interlocutor"], na.rm = TRUE), mean(df_field_cosine_long$cosine_sim[df_field_cosine_long$direction == "Same Turn"], na.rm = TRUE)
) %>%
mutate(
across(c(User, LLM), ~round(., 3))
)
print(summary_results)
write_csv(summary_results, file.path(TABLES_DIR, "analysis_summary.csv"))
